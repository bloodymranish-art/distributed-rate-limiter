{
  "rules": [
    {
      "endpoint": "/api/resource",
      "algorithm": "token_bucket",
      "capacity": 5,
      "refill_rate": 1,
      "fail_mode": "open"
    },
    {
      "endpoint": "/api/search",
      "algorithm": "sliding_window",
      "limit": 10,
      "window_size_seconds": 5,
      "fail_mode": "closed"
    }
  ],
  "default": {
    "algorithm": "token_bucket",
    "capacity": 10,
    "refill_rate": 2,
    "fail_mode": "open"
  }
}
